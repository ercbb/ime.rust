// === IME Keyboard Shared Structs ===

export struct KeyValue {
    label: string,
    id: string,
    key-width: length,
}

export struct CandidateItem {
    text: string,
    index: int,
}

// === Virtual Keyboard Key Button ===

export component KeyButton inherits Rectangle {
    in property <string> key-label: "";
    in property <string> key-id: "";
    in property <length> key-w: 56px;
    in property <length> key-h: 52px;
    in property <bool> flashing: false;
    callback clicked();

    width: key-w;
    height: key-h;
    border-radius: 6px;
    background: flashing ? #008cf0 : #f5f5f5ee;
    border-width: flashing ? 2px : 1px;
    border-color: flashing ? #0064b4 : #c8c8c8a0;
    animate background { duration: 120ms; easing: ease-out; }

    Text {
        text: root.key-label;
        color: flashing ? white : #282828;
        font-size: root.key-h * 0.36;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// === Candidate Bar ===

export component CandidateBar inherits Rectangle {
    height: 48px;

    in property <string> mode-indicator: "中";
    in property <color> mode-color: #0078d7;
    in property <string> input-buffer: "";
    in property <[CandidateItem]> candidates: [];
    in property <[CandidateItem]> associations: [];
    in property <bool> show-associations: false;
    in property <bool> has-prev-page: false;
    in property <bool> has-next-page: false;

    callback candidate-selected(int);
    callback association-selected(string);
    callback prev-page();
    callback next-page();

    // Associations row
    HorizontalLayout {
        visible: root.show-associations;
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 12px;
        alignment: start;

        Rectangle {
            width: 32px; height: 28px; border-radius: 3px;
            background: root.mode-color;
            Text { text: root.mode-indicator; font-size: 16px; color: white; horizontal-alignment: center; vertical-alignment: center; }
        }

        Text { text: root.input-buffer; font-size: 18px; color: red; vertical-alignment: center; width: 20px; }
        //Text { text: root.input-buffer; font-size: 18px; color: root.mode-color; vertical-alignment: center; width: 20px; }

        for assoc in root.associations: Rectangle {
            min-width: 48px; height: 36px; border-radius: 4px;
            background: #f0f0f0ee; border-width: 1px; border-color: #d0d0d0a0;
            Text { text: assoc.text; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { clicked => { root.association-selected(assoc.text); } }
        }
    }

    // Candidates row
    HorizontalLayout {
        visible: !root.show-associations;
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 12px;

        Rectangle {
            width: 36px; height: 36px; border-radius: 3px;
            background: root.mode-color;
            Text { text: root.mode-indicator; font-size: 24px; color: white; horizontal-alignment: center; vertical-alignment: center; }
        }

        Text { text: root.input-buffer; font-size: 20px; color: red; vertical-alignment: center; width: 70px; }

        for cand[idx] in root.candidates: Rectangle {
            min-width: 48px; height: 36px; border-radius: 4px;
            background: idx == 0 ? #0064b4 : #f0f0f0ee;
            border-width: 1px; border-color: idx == 0 ? #004680 : #d0d0d0a0;
            Text { text: cand.text; font-size: 20px; color: idx == 0 ? white : #1e1e1e; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { clicked => { root.candidate-selected(idx); } }
        }

        Rectangle { horizontal-stretch: 1; }

        Rectangle {
            height: 36px; width: 48px; border-radius: 4px;
            background: root.has-prev-page ? #e0e0e0dd : #f0f0f040;
            border-width: 1px; border-color: #c0c0c0a0;
            Text { text: "◂"; font-size: 32px; color: root.has-prev-page ? #3fd90c : #bbb; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { clicked => { root.prev-page(); } }
        }

        Rectangle {
            height: 36px; width: 48px; border-radius: 4px;
            background: root.has-next-page ? #e0e0e0dd : #f0f0f040;
            border-width: 1px; border-color: #c0c0c0a0;
            Text { text: "▸"; font-size: 32px; color: root.has-next-page ? #3fd90c : #bbb; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { clicked => { root.next-page(); } }
        }
    }
}

// === Keyboard Rows Panel ===

export component KeyboardRows inherits Rectangle {
    in property <length> key-height: 52px;
    in property <length> key-gap: 4px;
    in property <[KeyValue]> row1-keys: [];
    in property <[KeyValue]> row2-keys: [];
    in property <[KeyValue]> row3-keys: [];
    in property <[KeyValue]> row4-keys: [];
    in property <[KeyValue]> func-keys: [];
    in property <string> active-key: "";
    in property <float> kb-opacity: 0.85;

    callback key-pressed(string);

    vertical-stretch: 1;

    VerticalLayout {
        padding-top: 4px;
        padding-bottom: 10px;
        padding-left: 4px;
        padding-right: 4px;
        spacing: root.key-gap;
        alignment: center;

        HorizontalLayout { alignment: center; spacing: root.key-gap;
            for k in root.row1-keys: KeyButton { key-label: k.label; key-id: k.id; key-w: k.key-width > 0px ? k.key-width : 56px; key-h: root.key-height; flashing: root.active-key == k.id; clicked => { root.key-pressed(k.id); } }
        }
        HorizontalLayout { alignment: center; spacing: root.key-gap;
            for k in root.row2-keys: KeyButton { key-label: k.label; key-id: k.id; key-w: k.key-width > 0px ? k.key-width : 56px; key-h: root.key-height; flashing: root.active-key == k.id; clicked => { root.key-pressed(k.id); } }
        }
        HorizontalLayout { alignment: center; spacing: root.key-gap;
            for k in root.row3-keys: KeyButton { key-label: k.label; key-id: k.id; key-w: k.key-width > 0px ? k.key-width : 56px; key-h: root.key-height; flashing: root.active-key == k.id; clicked => { root.key-pressed(k.id); } }
        }
        HorizontalLayout { visible: root.row4-keys.length > 0; alignment: center; spacing: root.key-gap;
            for k in root.row4-keys: KeyButton { key-label: k.label; key-id: k.id; key-w: k.key-width > 0px ? k.key-width : 56px; key-h: root.key-height; flashing: root.active-key == k.id; clicked => { root.key-pressed(k.id); } }
        }
        HorizontalLayout { alignment: center; spacing: root.key-gap;
            for k in root.func-keys: KeyButton { key-label: k.label; key-id: k.id; key-w: k.key-width > 0px ? k.key-width : 64px; key-h: root.key-height; flashing: root.active-key == k.id; clicked => { root.key-pressed(k.id); } }
        }
    }
}
