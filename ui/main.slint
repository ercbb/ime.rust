import { Button, VerticalBox, HorizontalBox, LineEdit, ScrollView, GridBox, TextEdit } from "std-widgets.slint";
import { CandidateItem, KeyboardPanel, ImeState } from "../src/ime/ui/keyboard.slint";

// === Main Window ===

export component MainWindow inherits Window
{
    title: "Wheel IME";
    preferred-width: 800px;
    preferred-height: 480px;
    default-font-family: "Noto Sans CJK SC, PingFang SC, Microsoft YaHei, sans-serif";

    // --- Host-only ---
    in-out property <image> bg-image: @image-url("assets/bg.png");
    in-out property <bool> show-ime: false;
    in-out property <float> kb-opacity: 0.85;

    // --- IME state (owned by host, synced to global for keyboard access) ---
    in-out property <string> output-text <=> ImeState.output-text;
    in-out property <string> text-before-cursor <=> ImeState.text-before-cursor;
    in-out property <string> text-after-cursor <=> ImeState.text-after-cursor;
    in-out property <string> input-buffer <=> ImeState.input-buffer;
    in-out property <string> mode-indicator <=> ImeState.mode-indicator;
    in-out property <color> mode-color <=> ImeState.mode-color;
    in-out property <[CandidateItem]> candidates <=> ImeState.candidates;
    in-out property <[CandidateItem]> associations <=> ImeState.associations;
    in-out property <bool> show-associations <=> ImeState.show-associations;
    in-out property <bool> has-prev-page <=> ImeState.has-prev-page;
    in-out property <bool> has-next-page <=> ImeState.has-next-page;
    in-out property <bool> symbol-mode <=> ImeState.symbol-mode;
    in-out property <bool> caps-lock <=> ImeState.caps-lock;
    in-out property <string> mode-tag <=> ImeState.mode-tag;
    in-out property <string> cn-method <=> ImeState.cn-method;

    // Per-box text buffers (host owns these)
    in-out property <string> text-english: "good boy";
    in-out property <string> text-symbols: "12345";
    in-out property <string> text-full: "全拼";
    in-out property <string> text-double: "双拼";
    in-out property <int> active-box: -1;

    // --- Callbacks to Rust ---
    callback key-pressed(string);
    callback candidate-selected(int);
    callback association-selected(string);
    callback prev-page();
    callback next-page();
    callback show-keyboard-with-mode(string);
    callback show-keyboard();
    callback hide-keyboard();

    // === Background image ===
    Image {
        source: root.bg-image;
        width: 100%;
        height: 100%;
    }

    // === Main layout (always full height, never pushed by keyboard) ===
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Text Output Display
        Rectangle {
            height: 36px;
            background: transparent;

            Text {
                text: root.output-text == "" ? "" : root.output-text + "|";
                font-size: 18px;
                color: #fff;
                vertical-alignment: center;
            }
        }

        // Four Mode-specific Text Boxes
        Rectangle {
            vertical-stretch: 1;
            background: transparent;

            GridLayout {
                padding: 8px;
                spacing: 8px;

                Row {
                    // English mode box
                    Rectangle {
                        background: root.active-box == 0 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 0 ? 2px : 1px;
                        border-color: root.active-box == 0 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "english";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-english;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("english"); }
                        }
                    }

                    // Symbols (numbers) mode box
                    Rectangle {
                        background: root.active-box == 1 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 1 ? 2px : 1px;
                        border-color: root.active-box == 1 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "symbols";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-symbols;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("symbols"); }
                        }
                    }
                }

                Row {
                    // Chinese full pinyin mode box
                    Rectangle {
                        background: root.active-box == 2 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 2 ? 2px : 1px;
                        border-color: root.active-box == 2 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "全拼";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-full;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("full"); }
                        }
                    }

                    // Chinese double pinyin mode box
                    Rectangle {
                        background: root.active-box == 3 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 3 ? 2px : 1px;
                        border-color: root.active-box == 3 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "双拼";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-double;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("double"); }
                        }
                    }
                }
            }
        }
    }

    // === Keyboard overlay (absolutely positioned, floats above main layout) ===
    if root.show-ime: Rectangle
    {
        x: 0;
        y: root.height - 384px;
        width: root.width;
        height: 384px;
        background: #00000050;

        // Catch-all touch area: eat clicks on empty space so they don't fall through to host
        TouchArea { }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            KeyboardPanel {
                kb-opacity: root.kb-opacity;
                output-text <=> ImeState.output-text;
                input-buffer: ImeState.input-buffer;
                mode-indicator: ImeState.mode-indicator;
                mode-color: ImeState.mode-color;
                candidates: ImeState.candidates;
                associations: ImeState.associations;
                show-associations: ImeState.show-associations;
                has-prev-page: ImeState.has-prev-page;
                has-next-page: ImeState.has-next-page;
                text-before-cursor: ImeState.text-before-cursor;
                text-after-cursor: ImeState.text-after-cursor;
                symbol-mode: ImeState.symbol-mode;
                caps-lock: ImeState.caps-lock;
                mode-tag: ImeState.mode-tag;
                cn-method: ImeState.cn-method;

                key-pressed(id) => { root.key-pressed(id); }
                candidate-selected(idx) => { root.candidate-selected(idx); }
                association-selected(text) => { root.association-selected(text); }
                prev-page() => { root.prev-page(); }
                next-page() => { root.next-page(); }
                hide-keyboard() => { root.hide-keyboard(); }
            }

            // Bottom margin (click to hide keyboard)
            Rectangle {
                height: 24px;
                background: transparent;

                TouchArea {
                    clicked => { root.hide-keyboard(); }
                }
            }
        }
    }
}
