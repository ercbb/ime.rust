import { Button, VerticalBox, HorizontalBox, LineEdit, ScrollView, GridBox, TextEdit } from "std-widgets.slint";
import { CandidateItem, KeyboardPanel } from "../src/ime/ui/keyboard.slint";

// === Main Window ===

export component MainWindow inherits Window {
    title: "Wheel IME";
    preferred-width: 800px;
    preferred-height: 480px;
    default-font-family: "Noto Sans CJK SC, PingFang SC, Microsoft YaHei, sans-serif";

    // --- Layout Config ---
    in-out property <length> kb-width: 600px;
    in-out property <length> kb-height: 320px;
    in-out property <length> kb-bottom-margin: 40px;
    in-out property <length> key-height: 52px;
    in-out property <length> key-gap: 4px;
    in-out property <length> key-w: 56px;
    in-out property <length> mode-w: 112px;
    in-out property <length> space-w: 168px;
    in-out property <length> ctrl-w: 64px;
    in-out property <float> kb-opacity: 0.85;
    in-out property <image> bg-image: @image-url("assets/bg.png");

    // --- Data Properties ---
    in-out property <string> output-text: "";
    in-out property <string> text-before-cursor: "";
    in-out property <string> text-after-cursor: "";
    in-out property <string> input-buffer: "";
    in-out property <string> mode-indicator: "中";
    in-out property <color> mode-color: #0078d7;
    in-out property <[CandidateItem]> candidates: [];
    in-out property <[CandidateItem]> associations: [];
    in-out property <bool> show-associations: false;
    in-out property <bool> has-prev-page: false;
    in-out property <bool> has-next-page: false;
    in-out property <bool> symbol-mode: false;
    in-out property <bool> caps-lock: false;
    in-out property <string> mode-tag: "full";
    in-out property <string> cn-method: "full";
    in-out property <bool> show-ime: false;

    // Per-box text buffers
    in-out property <string> text-english: "good boy";
    in-out property <string> text-symbols: "12345";
    in-out property <string> text-full: "全拼";
    in-out property <string> text-double: "双拼";
    in-out property <int> active-box: -1;

    // --- Callbacks to Rust ---
    callback key-pressed(string);
    callback candidate-selected(int);
    callback association-selected(string);
    callback prev-page();
    callback next-page();
    callback show-keyboard-with-mode(string);
    callback show-keyboard();
    callback hide-keyboard();

    // === Background image ===
    Image {
        source: root.bg-image;
        width: 100%;
        height: 100%;
    }

    // === Foreground layout ===
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // === Text Output Display ===
        Rectangle {
            height: 36px;
            background: transparent;

            Text {
                text: root.output-text == "" ? "" : root.output-text + "|";
                font-size: 18px;
                color: #fff;
                vertical-alignment: center;
            }
        }

        // === Four Mode-specific Text Boxes ===
        Rectangle {
            vertical-stretch: 1;
            background: transparent;

            GridLayout {
                padding: 8px;
                spacing: 8px;

                Row {
                    // English mode box
                    Rectangle {
                        background: root.active-box == 0 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 0 ? 2px : 1px;
                        border-color: root.active-box == 0 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "english";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-english;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("english"); }
                        }
                    }

                    // Symbols (numbers) mode box
                    Rectangle {
                        background: root.active-box == 1 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 1 ? 2px : 1px;
                        border-color: root.active-box == 1 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "symbols";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-symbols;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("symbols"); }
                        }
                    }
                }

                Row {
                    // Chinese full pinyin mode box
                    Rectangle {
                        background: root.active-box == 2 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 2 ? 2px : 1px;
                        border-color: root.active-box == 2 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "全拼";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-full;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("full"); }
                        }
                    }

                    // Chinese double pinyin mode box
                    Rectangle {
                        background: root.active-box == 3 ? #ffffff30 : #ffffff18;
                        border-radius: 8px;
                        border-width: root.active-box == 3 ? 2px : 1px;
                        border-color: root.active-box == 3 ? #008cf0 : #ffffff33;
                        padding: 8px;
                        min-height: 80px;

                        VerticalLayout {
                            Text {
                                text: "双拼";
                                font-size: 11px;
                                color: #aaa;
                            }
                            Text {
                                text: root.text-double;
                                font-size: 18px;
                                color: #fff;
                            }
                        }

                        TouchArea {
                            clicked => { root.show-keyboard-with-mode("double"); }
                        }
                    }
                }
            }
        }

        // === Keyboard Panel (self-contained control) ===
        if root.show-ime: KeyboardPanel {
            kb-width: root.kb-width;
            kb-height: root.kb-height;
            key-height: root.key-height;
            key-gap: root.key-gap;
            key-w: root.key-w;
            mode-w: root.mode-w;
            space-w: root.space-w;
            ctrl-w: root.ctrl-w;
            kb-opacity: root.kb-opacity;
            symbol-mode: root.symbol-mode;
            caps-lock: root.caps-lock;
            mode-tag: root.mode-tag;
            cn-method: root.cn-method;

            output-text <=> root.output-text;
            input-buffer: root.input-buffer;
            mode-indicator: root.mode-indicator;
            mode-color: root.mode-color;
            candidates: root.candidates;
            associations: root.associations;
            show-associations: root.show-associations;
            has-prev-page: root.has-prev-page;
            has-next-page: root.has-next-page;
            text-before-cursor: root.text-before-cursor;
            text-after-cursor: root.text-after-cursor;

            key-pressed(id) => { root.key-pressed(id); }
            candidate-selected(idx) => { root.candidate-selected(idx); }
            association-selected(text) => { root.association-selected(text); }
            prev-page() => { root.prev-page(); }
            next-page() => { root.next-page(); }
            hide-keyboard() => { root.hide-keyboard(); }
        }

        // Bottom margin (click to hide IME)
        Rectangle {
            height: root.kb-bottom-margin;
            background: transparent;

            TouchArea {
                clicked => { root.hide-keyboard(); }
            }
        }
    }
}
